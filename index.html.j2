<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pickle Me Queer – Queer Pickleball in Philly</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;900&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --color-purple: #5b2d8e;
      --color-orange: #ff6b1a;
      --color-text: #333;
      --color-text-muted: #555;
      --color-text-faint: #888;
      --color-bg: #ffffff;
      --color-bg-purple: #f3eeff;
      --color-bg-orange: #fff4ee;
      --color-border: #f0ece4;
      --color-divider: #e0d9cc;

      --radius-card: 12px;
      --radius-lg: 16px;
      --radius-pill: 50px;

      --fw-bold: 700;
      --fw-extrabold: 800;
      --fw-black: 900;

      --fs-xs: 11px;
      --fs-sm: 13px;
      --fs-base: 15px;
      --fs-md: 16px;
      --fs-lg: 26px;
    }

    body {
      font-family: 'Nunito', Arial, sans-serif;
      color: var(--color-text);
      background: var(--color-bg);
    }

    .rainbow-stripe {
      display: flex;
      height: 6px;
    }

    .rainbow-stripe span {
      flex: 1;
    }

    a {
      color: var(--color-purple);
    }

    /* ---- Header ---- */

    .header {
      background: var(--color-bg-purple);
      text-align: center;
      padding: 48px 24px 40px;
    }

    .header img {
      width: 140px;
      height: 140px;
      object-fit: cover;
      border-radius: 50%;
    }

    .header h1 {
      color: var(--color-purple);
      font-size: 36px;
      font-weight: var(--fw-black);
      text-transform: uppercase;
      letter-spacing: -0.5px;
      margin: 16px 0 0;
    }

    .header p {
      color: var(--color-purple);
      font-size: var(--fs-md);
      font-weight: var(--fw-bold);
      margin: 8px 0 0;
      line-height: 1.5;
      opacity: 0.85;
    }

    /* ---- Sections ---- */

    section {
      max-width: 680px;
      margin: 0 auto;
      padding: 48px 24px;
    }

    section h2 {
      font-size: var(--fs-lg);
      font-weight: var(--fw-black);
      margin-bottom: 16px;
    }

    section p {
      font-size: var(--fs-base);
      line-height: 1.7;
      color: var(--color-text-muted);
    }

    .divider {
      max-width: 680px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .divider hr {
      border: none;
      height: 1px;
      background: var(--color-divider);
    }

    /* ---- Welcome ---- */

    .welcome {
      text-align: center;
    }

    .welcome h2 {
      color: var(--color-purple);
    }

    .welcome p {
      max-width: 520px;
      margin: 0 auto;
    }

    /* ---- Events ---- */


    .events .location-link {
      display: block;
      text-decoration: none;
      color: inherit;
      cursor: pointer;
      margin-bottom: 20px;
      border-radius: var(--radius-card);
      transition: filter 0.15s;
    }

    .events .location-link:active {
      filter: brightness(0.92);
    }

    .events .location-block {
      background: var(--color-bg-orange);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-card);
      padding: 14px 18px;
    }

    .events .location-label {
      color: var(--color-orange);
      font-size: 12px;
      font-weight: var(--fw-black);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 2px;
    }

    .events .location-block .details {
      font-size: var(--fs-sm);
      font-weight: var(--fw-bold);
      line-height: 1.6;
      color: var(--color-text);
    }

    .event-list {
      list-style: none;
      background: var(--color-bg);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      overflow: hidden;
    }

    .event-list li {
      display: flex;
      align-items: center;
      padding: 14px 16px;
      gap: 14px;
    }

    .event-list li+li {
      border-top: 1px solid var(--color-border);
    }

    .event-date {
      width: 52px;
      height: 52px;
      border-radius: var(--radius-card);
      color: #fff;
      font-weight: var(--fw-black);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .event-date .month {
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: 1px;
      opacity: 0.85;
    }

    .event-date .day {
      font-size: 20px;
      line-height: 1;
    }

    .event-details {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
    }

    .event-info {
      font-weight: var(--fw-bold);
      font-size: var(--fs-base);
    }

    .event-time {
      font-size: var(--fs-xs);
      font-weight: var(--fw-bold);
      color: var(--color-orange);
      background: var(--color-bg-orange);
      border-radius: var(--radius-pill);
      padding: 4px 10px;
      white-space: nowrap;
    }

    /* ---- Info sections (values, guidelines, FAQ, CTA) ---- */

    .info-section h2 {
      color: var(--color-purple);
    }

    /* ---- Definition lists (guidelines, FAQ) ---- */

    .dl-list {
      margin-top: 8px;
      text-align: left;
    }

    .dl-list dt {
      font-weight: var(--fw-black);
      font-size: var(--fs-base);
      margin-top: 20px;
      color: var(--color-purple);
    }

    .dl-list dd {
      font-size: var(--fs-base);
      line-height: 1.7;
      color: var(--color-text-muted);
      margin-top: 4px;
    }

    /* ---- Values cards ---- */

    .values-list {
      list-style: none;
      margin-top: 24px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .values-list li {
      background: var(--color-bg-purple);
      border-radius: var(--radius-card);
      padding: 18px 20px;
    }

    .values-list li strong {
      display: block;
      color: var(--color-purple);
      font-size: var(--fs-base);
      font-weight: var(--fw-black);
      margin-bottom: 4px;
    }

    .values-list li span {
      font-size: 14px;
      line-height: 1.6;
      color: var(--color-text-muted);
    }

    .cta p {
      color: var(--color-text-muted);
      margin-bottom: 20px;
    }

    .cta-buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .cta-buttons a {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 14px 20px;
      border-radius: var(--radius-pill);
      font-size: 14px;
      font-weight: var(--fw-extrabold);
      text-decoration: none;
    }

    .cta-buttons img {
      width: 18px;
      height: 18px;
    }

    .cta-discord {
      background: #5865f2;
      color: #fff;
    }

    .cta-newsletter {
      background: var(--color-orange);
      color: #fff;
    }

    .cta-host {
      background: var(--color-bg);
      color: var(--color-text);
      border: 2px solid var(--color-text);
    }

    /* ---- Footer ---- */

    .footer {
      background: var(--color-bg-purple);
      text-align: center;
      padding: 40px 24px;
    }

    .footer img.logo {
      width: 60px;
      height: 60px;
      object-fit: cover;
      border-radius: 50%;
      margin-bottom: 16px;
    }

    .footer-links {
      display: flex;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
      margin-bottom: 24px;
    }

    .footer-links a {
      color: var(--color-purple);
      text-decoration: none;
      font-size: var(--fs-sm);
      font-weight: var(--fw-bold);
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .footer-links a:hover {
      text-decoration: underline;
    }

    .footer-links img {
      width: 16px;
      height: 16px;
    }

    .newsletter-form {
      max-width: 420px;
      margin: 0 auto 24px;
    }

    .newsletter-form h3 {
      font-size: var(--fs-md);
      font-weight: var(--fw-black);
      margin-bottom: 10px;
    }

    .newsletter-form .form-row {
      display: flex;
      gap: 8px;
    }

    .newsletter-form input[type="email"] {
      flex: 1;
      padding: 12px 16px;
      border: 2px solid var(--color-divider);
      border-radius: var(--radius-pill);
      font-family: 'Nunito', Arial, sans-serif;
      font-size: 14px;
      outline: none;
    }

    .newsletter-form input[type="email"]:focus {
      border-color: var(--color-purple);
    }

    .newsletter-form button {
      background: var(--color-orange);
      color: #fff;
      border: none;
      border-radius: var(--radius-pill);
      padding: 12px 24px;
      font-family: 'Nunito', Arial, sans-serif;
      font-size: 14px;
      font-weight: var(--fw-extrabold);
      cursor: pointer;
    }

    .newsletter-form button:hover {
      background: #e85d10;
    }

    .newsletter-hint {
      font-size: var(--fs-xs);
      color: var(--color-text-faint);
      margin: 8px 0 0;
    }

    .newsletter-success {
      font-size: 14px;
      font-weight: var(--fw-bold);
      color: var(--color-purple);
      margin: 0;
    }

    .footer-email {
      font-size: 12px;
      color: var(--color-text-faint);
    }

    .footer-email a {
      color: var(--color-purple);
      text-decoration: none;
    }

    /* ---- Responsive ---- */

    @media (max-width: 520px) {
      .header h1 {
        font-size: 28px;
      }

      .event-details {
        flex-direction: column;
        align-items: flex-start;
      }

      .newsletter-form .form-row {
        flex-direction: column;
      }

      .newsletter-form button {
        width: 100%;
      }

      .values-list {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>

  <!-- Rainbow stripe -->
  <div class="rainbow-stripe">
    <span style="background:#784F17"></span>
    <span style="background:#000"></span>
    <span style="background:#E40303"></span>
    <span style="background:#FF8C00"></span>
    <span style="background:#FFED00"></span>
    <span style="background:#008026"></span>
    <span style="background:#004DFF"></span>
    <span style="background:#750787"></span>
  </div>

  <!-- Header -->
  <header class="header">
    <img src="{{ links.logo }}" alt="Pickle Me Queer Logo">
    <h1>Pickle Me Queer</h1>
    <p>A queer Philly group that plays pickleball<br>and where all skill levels are welcome 🌈</p>
  </header>

  <!-- Rainbow stripe -->
  <div class="rainbow-stripe">
    <span style="background:#784F17"></span>
    <span style="background:#000"></span>
    <span style="background:#E40303"></span>
    <span style="background:#FF8C00"></span>
    <span style="background:#FFED00"></span>
    <span style="background:#008026"></span>
    <span style="background:#004DFF"></span>
    <span style="background:#750787"></span>
  </div>

  <!-- Special Events -->
  {% if special_events %}
  <section class="events">
    <h2>Special Events</h2>

    <ul class="event-list">
      {% for event in special_events %}
      <li>
        <div class="event-date" style="background:{{ event.color }}">
          <span class="month">{{ event.month }}</span>
          <span class="day">{{ event.day }}</span>
        </div>
        <div class="event-details">
          <div class="event-info">{{ event.hosts }}</div>
          <span class="event-time">{{ event.weekday }} · {{ event.time }}</span>
        </div>
      </li>
      {% endfor %}
    </ul>
  </section>

  <div class="divider">
    <hr>
  </div>
  {% endif %}

  <!-- Gameplay Events -->
  <section class="events">
    <h2>Recent & Upcoming Sessions</h2>

    <a href="{{ locations.west_philly.google_maps }}" target="_blank" rel="noopener" class="location-link">
      <div class="location-block">
        <div class="location-label">📍 Location</div>
        <div class="details">
          {{ locations.west_philly.name }}<br>
          {{ locations.west_philly.address }}
        </div>
      </div>
    </a>

    <ul class="event-list">
      {% for event in events %}
      <li>
        <div class="event-date" style="background:{{ event.color }}">
          <span class="month">{{ event.month }}</span>
          <span class="day">{{ event.day }}</span>
        </div>
        <div class="event-details">
          <div class="event-info">{{ event.hosts }}</div>
          <span class="event-time">{{ event.weekday }} · {{ event.time }}</span>
        </div>
      </li>
      {% endfor %}
    </ul>
  </section>

  <div class="divider">
    <hr>
  </div>

  <!-- Values -->
  <section class="values info-section">
    <h2>Our Values</h2>
    <ul class="values-list">
      <li>
        <strong>Inclusion</strong>
        <span>Equal access to opportunities and resources for people who might otherwise be excluded or marginalized to play pickleball.</span>
      </li>
      <li>
        <strong>Accessibility</strong>
        <span>Designing a pickleball community in which all people are able to enjoy the benefits of the sport experience.</span>
      </li>
      <li>
        <strong>Safety</strong>
        <span>Ensuring everyone feels and is both physically and psychologically cared for.</span>
      </li>
      <li>
        <strong>Fun</strong>
        <span>As queer people, this is a place to show up as ourselves to play, compete, make new friends, and have fun.</span>
      </li>
    </ul>
  </section>

  <div class="divider">
    <hr>
  </div>

  <!-- Community Guidelines -->
  <section class="guidelines info-section">
    <h2>Community Guidelines</h2>
    <dl class="dl-list">
      <dt>Be respectful of the community</dt>
      <dd>We are building a queer-centered group and we want to ensure the safety and joy of this group.</dd>

      <dt>Be respectful of all players</dt>
      <dd>Be a good sport (win or lose), be honest, fair, and be conscientious of everyone's experience.</dd>

      <dt>Be here and be queer</dt>
      <dd>We are here first and foremost to have fun, so don't be a sour pickle!</dd>
    </dl>
  </section>

  <div class="divider">
    <hr>
  </div>



  <!-- FAQ -->
  <section class="faq info-section">
    <h2>FAQs</h2>
    <dl class="dl-list">
      <dt>Do I need my own paddle?</dt>
      <dd>Nope! We have loaner paddles available at every session.</dd>

      <dt>Do I need to know how to play?</dt>
      <dd>Not at all. We welcome complete beginners and are happy to teach you the basics.</dd>

      <dt>Is this only for LGBTQ+ people?</dt>
      <dd>We're a queer-centered group, but community members are absolutely welcome.</dd>

      <dt>Do I need to sign up in advance?</dt>
      <dd>Nope, just show up! Check our socials for the most up-to-date schedule in case anything changes.</dd>

      <dt>How much does it cost?</dt>
      <dd>It's completely free! Our sessions are community-organized at public courts.</dd>

      <dt>What should I bring?</dt>
      <dd>Just yourself, water, and comfy shoes you can move in.</dd>
    </dl>
  </section>

  <div class="divider">
    <hr>
  </div>

  <!-- Come hang with us -->
  <section class="cta info-section">
    <h2>Come hang with us!</h2>
    <p>Join our community, stay in the loop, or become a host.</p>
    <div class="cta-buttons">
      <a href="{{ links.discord }}" class="cta-discord">
        <img src="https://cdn.simpleicons.org/discord/ffffff" alt=""> Join our Discord
      </a>
      <a href="#newsletter" class="cta-newsletter" onclick="setTimeout(()=>document.querySelector('#newsletter input[type=email]').focus(),0)">
        👇🏼 Sign up for the Newsletter
      </a>
      <a href="{{ links.host_guide }}" class="cta-host">
        🏓 Become a Host
      </a>
    </div>
  </section>

  <!-- Footer -->
  <div class="rainbow-stripe">
    <span style="background:#784F17"></span>
    <span style="background:#000"></span>
    <span style="background:#E40303"></span>
    <span style="background:#FF8C00"></span>
    <span style="background:#FFED00"></span>
    <span style="background:#008026"></span>
    <span style="background:#004DFF"></span>
    <span style="background:#750787"></span>
  </div>

  <footer class="footer">
    <img class="logo" src="{{ links.logo }}" alt="PMQ Logo">

    <!-- Social links -->
    <div class="footer-links">
      <a href="{{ links.instagram }}">
        <img src="https://cdn.simpleicons.org/instagram/5b2d8e" alt=""> Instagram
      </a>
      <a href="{{ links.linktree }}">
        <img src="https://cdn.simpleicons.org/linktree/5b2d8e" alt=""> Linktree
      </a>
      <a href="{{ links.discord }}">
        <img src="https://cdn.simpleicons.org/discord/5b2d8e" alt=""> Discord
      </a>
      <a href="{{ links.google_calendar }}">
        <img src="https://cdn.simpleicons.org/googlecalendar/5b2d8e" alt=""> Calendar
      </a>
      <a href="{{ links.google_map }}">
        <img src="https://cdn.simpleicons.org/googlemaps/5b2d8e" alt=""> Locations
      </a>
    </div>

    <!-- Newsletter signup -->
    <div class="newsletter-form">
      <h3>📬 Stay in the loop</h3>
      <form id="newsletter" class="newsletter-fields">
        <div class="form-row">
          <input type="email" name="email_address" placeholder="Email Address" aria-label="Email Address" required>
          <button type="submit">Subscribe</button>
        </div>
        <p class="newsletter-hint">We send emails once a month with upcoming gameplay sessions.<br>Unsubscribe at any
          time.</p>
      </form>
      <p class="newsletter-success" hidden>You're in! Check your email to confirm.</p>
    </div>
    <script>
      document.getElementById('newsletter').addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target;
        const email = form.email_address.value;
        const btn = form.querySelector('button');
        btn.disabled = true;
        btn.textContent = '...';
        try {
          const res = await fetch('https://app.kit.com/forms/9157122/subscriptions', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email_address: email }),
          });
          if (res.ok) {
            form.hidden = true;
            form.nextElementSibling.hidden = false;
          } else {
            btn.textContent = 'Try again';
            btn.disabled = false;
          }
        } catch {
          btn.textContent = 'Try again';
          btn.disabled = false;
        }
      });
    </script>

    <p class="footer-email">
      Questions? Reach us at <a href="mailto:{{ links.email }}">{{ links.email }}</a>
    </p>
  </footer>

  <div class="rainbow-stripe">
    <span style="background:#784F17"></span>
    <span style="background:#000"></span>
    <span style="background:#E40303"></span>
    <span style="background:#FF8C00"></span>
    <span style="background:#FFED00"></span>
    <span style="background:#008026"></span>
    <span style="background:#004DFF"></span>
    <span style="background:#750787"></span>
  </div>

</body>

</html>
