<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pickle Me Queer – Upcoming Sessions</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;900&display=swap');
  </style>
</head>

<body style="margin:0; padding:0; background:#ffffff; font-family:'Nunito',Arial,sans-serif; color:#333;">

  <!-- ====== HEADER ====== -->

  <!-- Rainbow stripe -->
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" align="center"
    style="max-width:600px;">
    <tr>
      <td style="background:#784F17; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#000; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#E40303; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#FF8C00; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#FFED00; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#008026; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#004DFF; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#750787; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
    </tr>
  </table>

  <!-- Header content -->
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" align="center"
    style="max-width:600px; background:#f3eeff;">
    <tr>
      <td style="padding:32px 24px 24px; text-align:center;">
        <img src="{{ links.logo }}" alt="Pickle Me Queer Logo" width="120" height="120"
          style="display:block; margin:0 auto; width:120px; height:120px; object-fit:cover; border-radius:50%;">
        <h1
          style="color:#5b2d8e; font-size:28px; font-weight:900; letter-spacing:-0.5px; margin:12px 0 0; text-transform:uppercase; font-family:'Nunito',Arial,sans-serif;">
          Pickle Me Queer</h1>
        <p
          style="color:#5b2d8e; font-size:14px; font-weight:700; margin:6px 0 0; line-height:1.5; opacity:0.85; font-family:'Nunito',Arial,sans-serif;">
          A queer Philly group that plays pickleball <br>and where all skill levels are welcome 🌈</p>
      </td>
    </tr>
  </table>

  <!-- Rainbow stripe -->
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" align="center"
    style="max-width:600px;">
    <tr>
      <td style="background:#784F17; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#000; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#E40303; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#FF8C00; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#FFED00; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#008026; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#004DFF; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#750787; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
    </tr>
  </table>

  <!-- ====== EVENTS ====== -->

  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" align="center"
    style="max-width:600px;">
    <tr>
      <td style="padding:32px 24px;">
        <h2 style="font-size:22px; font-weight:900; margin:0 0 16px; font-family:'Nunito',Arial,sans-serif;">Upcoming
          Sessions</h2>

        <!-- Location block -->
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%"
          style="background:#fff4ee; border-radius:12px; margin-bottom:20px; border:1px solid #f0ece4;">
          <tr>
            <td
              style="padding:14px 18px; font-size:13px; font-weight:700; line-height:1.6; color:#333; font-family:'Nunito',Arial,sans-serif;">
              <div
                style="color:#ff6b1a; font-size:12px; font-weight:900; text-transform:uppercase; letter-spacing:1px; margin-bottom:2px;">
                📍 Location
              </div>
              {{ locations.west_philly.name }}<br>
              {{ locations.west_philly.address }}
            </td>
          </tr>
        </table>

        <!-- Events list -->
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%"
          style="background:#fff; border-radius:16px; border:1px solid #f0ece4;">
          {% for event in events %}
          <tr>
            <td style="padding:14px 10px;{% if not loop.last %} border-bottom:1px solid #f0ece4;{% endif %}">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                <tr>
                  <td width="52" valign="middle" style="padding-right:14px;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="52"
                      style="background:{{ event.color }}; border-radius:12px;">
                      <tr>
                        <td align="center"
                          style="width:52px; height:52px; color:#fff; font-weight:900; font-family:'Nunito',Arial,sans-serif; text-align:center; vertical-align:middle;">
                          <span
                            style="font-size:9px; text-transform:uppercase; letter-spacing:1px; opacity:0.85; display:block;">{{
                            event.month }}</span>
                          <span style="font-size:20px; line-height:1; display:block;">{{ event.day }}</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                  <td valign="middle" style="font-weight:700; font-size:15px; color:#333; font-family:'Nunito',Arial,sans-serif; vertical-align:middle;">{{ event.hosts }}</td>
                  <td width="1" valign="middle" align="right" style="white-space:nowrap;">
                    <span
                      style="font-size:11px; font-weight:700; color:#ff6b1a; background:#fff4ee; border-radius:20px; padding:4px 10px; font-family:'Nunito',Arial,sans-serif;">{{
                      event.weekday }} · {{ event.time }}</span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          {% endfor %}
        </table>
      </td>
    </tr>
  </table>

  <!-- ====== GET INVOLVED ====== -->

  <!-- Divider -->
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" align="center"
    style="max-width:600px;">
    <tr>
      <td style="padding:0 24px;">
        <div style="height:1px; background:#e0d9cc;"></div>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" align="center"
    style="max-width:600px;">
    <tr>
      <td style="padding:32px 24px;">
        <h2 style="font-size:22px; font-weight:900; margin:0 0 6px; font-family:'Nunito',Arial,sans-serif;">Come hang
          with us!</h2>
        <p style="font-size:13px; color:#555; margin:0 0 20px; line-height:1.5; font-family:'Nunito',Arial,sans-serif;">
          Join our community, stay in the loop, or become a host.</p>

        <!-- CTA: Discord -->
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-bottom:10px;">
          <tr>
            <td align="center" style="background:#5865f2; border-radius:50px;">
              <a href="{{ links.discord }}"
                style="display:block; padding:14px 20px; color:#fff; font-weight:800; font-size:14px; text-decoration:none; text-align:center; font-family:'Nunito',Arial,sans-serif;">
                <img src="https://cdn.simpleicons.org/discord/ffffff" alt="" width="18" height="18"
                  style="display:inline-block; vertical-align:middle; margin-right:6px; width:18px; height:18px;">
                Join our Discord
              </a>
            </td>
          </tr>
        </table>

        <!-- CTA: Newsletter -->
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-bottom:10px;">
          <tr>
            <td align="center" style="background:#ff6b1a; border-radius:50px;">
              <a href="{{ links.site }}#newsletter"
                style="display:block; padding:14px 20px; color:#fff; font-weight:800; font-size:14px; text-decoration:none; text-align:center; font-family:'Nunito',Arial,sans-serif;">
                📬 Sign up for the Newsletter
              </a>
            </td>
          </tr>
        </table>

        <!-- CTA: Become a Host -->
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
          <tr>
            <td align="center" style="background:#fff; border-radius:50px; border:2px solid #333;">
              <a href="{{ links.host_guide }}"
                style="display:block; padding:14px 20px; color:#333; font-weight:800; font-size:14px; text-decoration:none; text-align:center; font-family:'Nunito',Arial,sans-serif;">
                🏓 Become a Host
              </a>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <!-- ====== FOOTER ====== -->

  <!-- Rainbow stripe -->
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" align="center"
    style="max-width:600px;">
    <tr>
      <td style="background:#784F17; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#000; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#E40303; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#FF8C00; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#FFED00; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#008026; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#004DFF; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#750787; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
    </tr>
  </table>

  <!-- Footer content -->
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" align="center"
    style="max-width:600px; background:#f3eeff;">
    <tr>
      <td style="padding:28px 24px; text-align:center;">
        <img src="{{ links.logo }}" alt="PMQ Logo" width="60" height="60"
          style="display:block; margin:0 auto 16px; width:60px; height:60px; object-fit:cover; border-radius:50%;">

        <!-- Footer links -->
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center"
          style="margin:0 auto 14px;">
          <tr>
            <td style="padding:0 10px;">
              <a href="{{ links.instagram }}"
                style="color:#5b2d8e; text-decoration:none; font-size:12px; font-weight:700; font-family:'Nunito',Arial,sans-serif;">
                <img src="https://cdn.simpleicons.org/instagram/5b2d8e" alt="" width="14" height="14"
                  style="display:inline-block; vertical-align:middle; margin-right:3px; width:14px; height:14px;">
                Instagram
              </a>
            </td>
            <td style="padding:0 10px;">
              <a href="{{ links.linktree }}"
                style="color:#5b2d8e; text-decoration:none; font-size:12px; font-weight:700; font-family:'Nunito',Arial,sans-serif;">
                <img src="https://cdn.simpleicons.org/linktree/5b2d8e" alt="" width="14" height="14"
                  style="display:inline-block; vertical-align:middle; margin-right:3px; width:14px; height:14px;">
                Linktree
              </a>
            </td>
            <td style="padding:0 10px;">
              <a href="{{ links.discord }}"
                style="color:#5b2d8e; text-decoration:none; font-size:12px; font-weight:700; font-family:'Nunito',Arial,sans-serif;">
                <img src="https://cdn.simpleicons.org/discord/5b2d8e" alt="" width="14" height="14"
                  style="display:inline-block; vertical-align:middle; margin-right:3px; width:14px; height:14px;">
                Discord
              </a>
            </td>
            <td style="padding:0 10px;">
              <a href="{{ links.google_calendar_link }}"
                style="color:#5b2d8e; text-decoration:none; font-size:12px; font-weight:700; font-family:'Nunito',Arial,sans-serif;">
                <img src="https://cdn.simpleicons.org/googlecalendar/5b2d8e" alt="" width="14" height="14"
                  style="display:inline-block; vertical-align:middle; margin-right:3px; width:14px; height:14px;">
                Google Calendar
              </a>
            </td>
          </tr>
        </table>

        <p style="font-size:11px; color:#888; line-height:1.6; margin:0; font-family:'Nunito',Arial,sans-serif;">
          Questions? Reach us at
          <a href="mailto:{{ links.email }}" style="color:#5b2d8e; text-decoration:none;">{{ links.email }}</a><br><br>
          You're receiving this because you signed up for PMQ updates.<br>
          <a href="{{ '{{ unsubscribe_link }}' }}" style="color:#aaa; font-size:11px; text-decoration:none;">Unsubscribe</a>
        </p>
      </td>
    </tr>
  </table>

  <!-- Rainbow stripe -->
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" align="center"
    style="max-width:600px;">
    <tr>
      <td style="background:#784F17; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#000; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#E40303; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#FF8C00; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#FFED00; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#008026; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#004DFF; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
      <td style="background:#750787; height:6px; width:12.5%; font-size:0; line-height:0;">&nbsp;</td>
    </tr>
  </table>

</body>

</html>
